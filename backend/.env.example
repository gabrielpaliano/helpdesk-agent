OPENAI_API_KEY=sk-...
PORT=3000

# Optional: change model (gpt-4o-mini is cheaper for dev, gpt-4o for prod)
OPENAI_MODEL=gpt-4o-mini

# Rate limiting: max requests per session per minute
RATE_LIMIT_MAX=10
RATE_LIMIT_WINDOW_MS=60000

# PostgreSQL connection string
# For local dev: postgres://helpdesk:helpdesk@localhost:5432/helpdesk
# For Docker: set automatically by docker-compose (no need to change)
DATABASE_URL=postgres://helpdesk:helpdesk@localhost:5432/helpdesk
